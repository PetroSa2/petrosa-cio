# Environment Configuration Example for Petrosa CIO
# Copy this file to .env and fill in your values

# Environment
ENVIRONMENT=production
LOG_LEVEL=INFO

# NATS Configuration
NATS_URL=nats://localhost:4222
REDIS_URL=redis://localhost:6379

# Internal Service URLs
DATA_MANAGER_URL=http://petrosa-data-manager:80
TRADEENGINE_URL=http://petrosa-tradeengine-service:80
TA_BOT_URL=http://petrosa-ta-bot-service:80

# LLM Configuration
LLM_PROVIDER=mock
LLM_MODEL=anthropic/claude-3-haiku-20240307
LLM_FALLBACK_MODEL=openai/gpt-4o-mini
LLM_API_BASE=https://router.requesty.ai/v1
LLM_MODEL_PREFIX=openai/
LLM_SUPPORTS_JSON_MODE=true
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
REQUESTY_API_KEY=

# Vector DB Configuration
VECTOR_PROVIDER=mock
QDRANT_URL=
QDRANT_API_KEY=

# Rollout Control
DRY_RUN=true

# OpenTelemetry Configuration (Optional)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=petrosa-cio
